<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="order"
            type="com.example.assignment1.Order" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <ImageView
                android:id="@+id/iv_vehicle"
                android:layout_width="66dp"
                android:layout_height="76dp"
                android:src="@drawable/vehicle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_vehicle_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@{order.vehicleType}"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/iv_vehicle"
                app:layout_constraintTop_toTopOf="@+id/iv_vehicle" />

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{"₹ " + String.valueOf(order.price)}'
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_more"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_price" />

            <TextView
                android:id="@+id/tv_order_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text='@{order.dateString + "  |  Order ID: " + order.orderId}'
                android:textColor="#888888"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="@+id/tv_vehicle_type"
                app:layout_constraintTop_toBottomOf="@+id/tv_vehicle_type" />

            <TextView
                android:id="@+id/tv_pickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:drawablePadding="8dp"
                android:text="@{order.pickupLocation}"
                android:textColor="#333333"
                android:textSize="12sp"
                app:drawableStartCompat="@android:drawable/presence_online"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_vehicle_type"
                app:layout_constraintTop_toBottomOf="@+id/tv_order_details" />

            <TextView
                android:id="@+id/tv_drop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:drawablePadding="8dp"
                android:text="@{order.dropLocation}"
                android:textColor="#333333"
                android:textSize="12sp"
                app:drawableStartCompat="@android:drawable/presence_busy"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_vehicle_type"
                app:layout_constraintTop_toBottomOf="@+id/tv_pickup" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FFEBEE"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="@{order.status}"
                android:textColor="#D32F2F"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_drop" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_drop">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_invoice"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Invoice"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    app:icon="@android:drawable/stat_sys_download"
                    app:iconTint="#333333"
                    app:strokeColor="#CCCCCC" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_book_again"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Book Again"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:textColor="#000000"
                    app:backgroundTint="#FFD500" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>